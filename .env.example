# Core services
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USERNAME=root
MYSQL_PASSWORD=your_mysql_password

ZWIKI_REDIS_HOST=127.0.0.1
ZWIKI_REDIS_PORT=6379
ZWIKI_REDIS_DATABASE=6
ZWIKI_REDIS_PASSWORD=your_redis_password

NACOS_ENABLED=false
NACOS_SERVER_ADDR=127.0.0.1:8848
NACOS_NAMESPACE=public
NACOS_USERNAME=
NACOS_PASSWORD=

# LLM / AI
DASHSCOPE_API_KEY=your_llm_api_key
MEM0_API_KEY=your_mem0_api_key

# OAuth
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITEE_CLIENT_ID=your_gitee_client_id
GITEE_CLIENT_SECRET=your_gitee_client_secret

# Review / Webhook
GITHUB_TOKEN=your_github_pat
GITHUB_WEBHOOK_SECRET=your_github_webhook_secret

# Storage / Mail
MINIO_URL=http://127.0.0.1:9000
MINIO_ACCESS_KEY=your_minio_access_key
MINIO_SECRET_KEY=your_minio_secret_key
MINIO_BUCKET_NAME=zwiki
MAIL_ENABLED=false
MAIL_USERNAME=your_mail_username
MAIL_PASSWORD=your_mail_password

# Paths / Proxy
PROJECT_REPO_PATH=./data/repositories
ZWIKI_WORKSPACE_BASE_PATH=./data/workspace
GIT_PROXY_ENABLED=false
GIT_PROXY_HOST=127.0.0.1
GIT_PROXY_PORT=7897

# URLs
WIKI_SERVICE_URI=http://localhost:8991
REVIEW_SERVICE_URI=http://localhost:8990
MEMORY_SERVICE_URI=http://localhost:8993
WIKI_WS_URI=ws://localhost:8991
ZWIKI_AUTH_LOGIN_SUCCESS_REDIRECT=http://localhost:3000/
ZWIKI_MAIL_HOME_URL=http://localhost:3000
ZWIKI_MCP_API_KEYS=
API_PROXY_TARGET=http://localhost:8992
WS_PROXY_TARGET=ws://localhost:8992
